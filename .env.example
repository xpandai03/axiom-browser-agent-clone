# Axiom Playwright Service — environment variables.
# Copy this file to `.env` and fill in real values for local development.
# Production values are managed in the Railway dashboard.

# OpenAI (required for workflow parsing + resume tailoring)
OPENAI_API_KEY=

# Browser
BROWSER_HEADLESS=true

# TherapyNotes service account (only required for /api/tn/*)
THERAPYNOTES_PRACTICE_CODE=
THERAPYNOTES_USERNAME=
THERAPYNOTES_PASSWORD=

# API keys for caller-facing endpoints
TN_API_KEY=                   # gates /api/tn/*
EXTRACT_API_KEY=              # gates /api/extract/* (Wolfee URL extraction)

# IPRoyal residential proxy (currently broken — Chromium can't auth SOCKS5).
# /api/extract/* uses skip_proxy=True regardless.
API_PROXY_ENABLED=false
API_PROXY_SERVER=
API_PROXY_USERNAME=
API_PROXY_PASSWORD=
API_PROXY_COUNTRY=us
API_PROXY_SESSION=
